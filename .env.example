# API
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://drug:drug@postgres:5432/drug
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO

# Storage (local FS in dev; set STORAGE_BACKEND=r2 to use Cloudflare R2 in prod)
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/data/blobs
PUBLIC_BASE_URL=http://localhost:8000
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=drug-cell-viz
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Docking (Phase 2). false = use RDKit stub docker. true = call Modal DiffDock.
USE_MODAL_DOCKING=false
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_APP_NAME=drug-cell-viz
MODAL_DIFFDOCK_FN=dock_ligand

# JUMP-CP (Phase 3). Keys in the storage backend, populated by scripts/.
JUMP_FAISS_INDEX_KEY=indices/jump-v1.faiss
JUMP_METADATA_KEY=indices/jump-v1-meta.parquet

# Rate limiting (per IP)
RATE_LIMIT_JOBS_PER_HOUR=10

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
